#!/bin/bash
# dev — Start or stop ATWA server + frontend.
#
# Usage:
#   scripts/dev start [env]     # start all services (default: development)
#   scripts/dev stop [env]      # stop all services
#   scripts/dev [env]           # shorthand for start
#
# Services run in the background; output goes to log files under
# ~/.atwa/<env>/logs/.  PID files are stored under ~/.atwa/<env>/tmp/.

set -euo pipefail


# ---- Parse arguments ----
ACTION="start"
ENV="development"

for arg in "$@"; do
    case "$arg" in
        start|stop) ACTION="$arg" ;;
        development|production|test) ENV="$arg" ;;
        *)
            echo "ERROR: Unknown argument '$arg'. Use: start|stop [development|production|test]" >&2
            exit 1
            ;;
    esac
done

# ---- Resolve paths ----
ATWA_HOME="$HOME/.atwa/$ENV"
LOG_DIR="$ATWA_HOME/logs"
TMP_DIR="$ATWA_HOME/tmp"

SERVER_PID_FILE="$TMP_DIR/server.pid"
FRONTEND_PID_FILE="$TMP_DIR/frontend.pid"
SERVER_LOG="$LOG_DIR/server.log"
FRONTEND_LOG="$LOG_DIR/frontend.log"

# ---- Resolve server port from config ----
case "$ENV" in
    development) SERVER_PORT=8743 ;;
    production)  SERVER_PORT=8742 ;;
    test)        SERVER_PORT=8744 ;;
esac

SERVER_HOST="127.0.0.1"
FRONTEND_PORT=5173

# ---- Resolve project root ----
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# ---- Color helpers ----
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

log()  { echo -e "${GREEN}[atwa]${NC} $*"; }
info() { echo -e "${CYAN}[atwa]${NC} $*"; }
warn() { echo -e "${YELLOW}[atwa]${NC} $*"; }
err()  { echo -e "${RED}[atwa]${NC} $*"; }

# ============================================================
#  STOP
# ============================================================
do_stop() {
    local stopped=0

    # Kill a process and all its descendants (macOS compatible)
    kill_tree() {
        local pid=$1 sig=${2:-TERM}
        # Collect child PIDs recursively using pgrep
        local children
        children="$(pgrep -P "$pid" 2>/dev/null)" || true
        for child in $children; do
            kill_tree "$child" "$sig"
        done
        kill -s "$sig" "$pid" 2>/dev/null || true
    }

    for pid_file in "$FRONTEND_PID_FILE" "$SERVER_PID_FILE"; do
        local name
        name="$(basename "$pid_file" .pid)"
        if [[ -f "$pid_file" ]]; then
            local pid
            pid="$(cat "$pid_file")"
            if kill -0 "$pid" 2>/dev/null; then
                log "Stopping $name (pid $pid)..."
                kill_tree "$pid" TERM
                # Wait briefly for graceful shutdown
                for _i in $(seq 1 10); do
                    kill -0 "$pid" 2>/dev/null || break
                    sleep 0.3
                done
                # Force kill if still alive
                if kill -0 "$pid" 2>/dev/null; then
                    warn "$name did not exit gracefully, force killing..."
                    kill_tree "$pid" KILL
                fi
                log "$name stopped."
                ((stopped++)) || true
            else
                info "$name pid $pid is not running (stale pid file)."
            fi
            rm -f "$pid_file"
        fi
    done

    if [[ $stopped -eq 0 ]]; then
        info "No running services found for env=$ENV."
    fi
}

# ============================================================
#  START
# ============================================================
do_start() {
    # Ensure directories exist
    mkdir -p "$LOG_DIR" "$TMP_DIR"

    # Preflight: check if already running
    for pid_file in "$SERVER_PID_FILE" "$FRONTEND_PID_FILE"; do
        if [[ -f "$pid_file" ]]; then
            local pid
            pid="$(cat "$pid_file")"
            if kill -0 "$pid" 2>/dev/null; then
                local name
                name="$(basename "$pid_file" .pid)"
                err "$name is already running (pid $pid). Run 'scripts/dev stop $ENV' first."
                exit 1
            fi
            rm -f "$pid_file"
        fi
    done

    # Preflight: check conda env
    if [[ -n "${CONDA_DEFAULT_ENV:-}" ]]; then
        info "Conda env: $CONDA_DEFAULT_ENV"
    else
        warn "No conda env detected. Make sure 'atwa' env is activated."
    fi

    # Preflight: check frontend node_modules
    if [[ ! -d "$PROJECT_ROOT/frontend/node_modules" ]]; then
        log "Installing frontend dependencies..."
        (cd "$PROJECT_ROOT/frontend" && npm install)
    fi

    # ---- Start server ----
    log "Starting server [env=$ENV] on http://${SERVER_HOST}:${SERVER_PORT}"
    ATWA_ENV="$ENV" python -m uvicorn server.main:app \
        --host "$SERVER_HOST" \
        --port "$SERVER_PORT" \
        >> "$SERVER_LOG" 2>&1 &
    echo $! > "$SERVER_PID_FILE"

    # Wait for server to be ready
    info "Waiting for server to be ready..."
    for _i in $(seq 1 30); do
        if curl -sf "http://${SERVER_HOST}:${SERVER_PORT}/api/sessions" >/dev/null 2>&1; then
            break
        fi
        sleep 0.5
    done

    if ! curl -sf "http://${SERVER_HOST}:${SERVER_PORT}/api/sessions" >/dev/null 2>&1; then
        warn "Server did not become ready within 15s, but continuing anyway."
    fi

    # ---- Start frontend ----
    log "Starting frontend on http://localhost:${FRONTEND_PORT}"
    (cd "$PROJECT_ROOT/frontend" && VITE_API_PORT="$SERVER_PORT" VITE_API_HOST="$SERVER_HOST" npx vite --port "$FRONTEND_PORT") \
        >> "$FRONTEND_LOG" 2>&1 &
    echo $! > "$FRONTEND_PID_FILE"

    # ---- Summary ----
    echo ""
    log "====================================="
    log "  ATWA started  [env=$ENV]"
    log "====================================="
    log "  Frontend : http://localhost:${FRONTEND_PORT}"
    log "  Server   : http://${SERVER_HOST}:${SERVER_PORT}"
    log "  API docs : http://${SERVER_HOST}:${SERVER_PORT}/docs"
    log ""
    log "  Logs: $LOG_DIR/"
    log "  Stop: scripts/dev stop $ENV"
    log "====================================="
    echo ""
}

# ============================================================
#  Main dispatch
# ============================================================
case "$ACTION" in
    start) do_start ;;
    stop)  do_stop ;;
esac
