#!/bin/bash
# dev — Start ATWA server (with daemon) and frontend dev server.
#
# Usage:
#   scripts/dev                  # development env (default)
#   scripts/dev production       # production env
#   scripts/dev test             # test env
#
# The daemon runs as an asyncio Task inside the server process.

set -euo pipefail

# ---- Resolve environment ----
ENV="${1:-development}"
VALID_ENVS="development production test"
if ! echo "$VALID_ENVS" | grep -qw "$ENV"; then
    echo "ERROR: Invalid environment '$ENV'. Must be one of: $VALID_ENVS" >&2
    exit 1
fi

# ---- Resolve server port from config ----
# Default ports per environment (must match config/*.toml)
case "$ENV" in
    development) SERVER_PORT=8743 ;;
    production)  SERVER_PORT=8742 ;;
    test)        SERVER_PORT=8744 ;;
esac

SERVER_HOST="127.0.0.1"
FRONTEND_PORT=5173

# ---- Resolve project root ----
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# ---- Color helpers ----
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

log()  { echo -e "${GREEN}[atwa]${NC} $*"; }
info() { echo -e "${CYAN}[atwa]${NC} $*"; }
warn() { echo -e "${YELLOW}[atwa]${NC} $*"; }

# ---- Cleanup on exit ----
PIDS=()
cleanup() {
    echo ""
    log "Shutting down..."
    for pid in "${PIDS[@]}"; do
        if kill -0 "$pid" 2>/dev/null; then
            kill "$pid" 2>/dev/null || true
        fi
    done
    wait 2>/dev/null || true
    log "Stopped."
    exit 0
}
trap cleanup EXIT INT TERM

# ---- Preflight checks ----
# Check conda env
if [[ -n "${CONDA_DEFAULT_ENV:-}" ]]; then
    info "Conda env: $CONDA_DEFAULT_ENV"
else
    warn "No conda env detected. Make sure 'atwa' env is activated."
fi

# Check frontend node_modules
if [[ ! -d "$PROJECT_ROOT/frontend/node_modules" ]]; then
    log "Installing frontend dependencies..."
    (cd "$PROJECT_ROOT/frontend" && npm install)
fi

# ---- Start server (includes daemon) ----
log "Starting server [env=$ENV] on http://${SERVER_HOST}:${SERVER_PORT}"
ATWA_ENV="$ENV" python -m uvicorn server.main:app \
    --host "$SERVER_HOST" \
    --port "$SERVER_PORT" \
    &
PIDS+=($!)

# Wait for server to be ready
info "Waiting for server to be ready..."
for i in $(seq 1 30); do
    if curl -sf "http://${SERVER_HOST}:${SERVER_PORT}/api/sessions" >/dev/null 2>&1; then
        break
    fi
    sleep 0.5
done

if ! curl -sf "http://${SERVER_HOST}:${SERVER_PORT}/api/sessions" >/dev/null 2>&1; then
    warn "Server did not become ready within 15s, but continuing anyway."
fi

# ---- Start frontend ----
log "Starting frontend on http://localhost:${FRONTEND_PORT}"
(cd "$PROJECT_ROOT/frontend" && npx vite --port "$FRONTEND_PORT") &
PIDS+=($!)

# ---- Summary ----
echo ""
log "====================================="
log "  ATWA is running  [env=$ENV]"
log "====================================="
log "  Frontend : http://localhost:${FRONTEND_PORT}"
log "  Server   : http://${SERVER_HOST}:${SERVER_PORT}"
log "  API docs : http://${SERVER_HOST}:${SERVER_PORT}/docs"
log ""
log "  Press Ctrl+C to stop all services"
log "====================================="
echo ""

# Wait for any child to exit
wait
